# Environment variables for NextAuth.js Cognito integration

# NextAuth Configuration
NEXTAUTH_URL=https://d1rqv10nry9s54.cloudfront.net
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# AWS Cognito Configuration
COGNITO_CLIENT_ID=your-cognito-app-client-id
COGNITO_CLIENT_SECRET=your-cognito-app-client-secret
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/your-user-pool-id

# Database (optional - for session storage)
DATABASE_URL=mysql://user:password@localhost:3306/johnson_legal
